{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "ix/content-slider",
  "title": "Content Slider",
  "category": "design",
  "icon": "slides",
  "description": "A carousel for any sequential content — quotes, pullquotes, images, anything.",
  "keywords": ["testimonials", "quotes", "carousel", "slider"],
  "supports": {
    "html": false,
    "align": ["wide", "full"],
    "spacing": {
      "padding": true,
      "margin": true
    }
  },
  "attributes": {
    "showArrows": {
      "type": "boolean",
      "default": true
    },
    "autoplay": {
      "type": "boolean",
      "default": true
    },
    "autoplayInterval": {
      "type": "number",
      "default": 5
    }
  },
  "textdomain": "ix",
  "viewScript": "file:../../../../../dist/js/content-slider-view.js",
  "render": "file:./render.php"
}
