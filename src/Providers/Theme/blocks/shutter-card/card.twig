<div class="shutter-card">
    <span class="shutter-card__id" aria-hidden="true">{{ card_index }}</span>

    {% if title %}
        <h3 class="shutter-card__title">{{ title }}</h3>
    {% endif %}

    {% if subtitle %}
        <p class="shutter-card__subtitle">{{ subtitle }}</p>
    {% endif %}

    {% if description %}
        <p class="shutter-card__description">{{ description|raw }}</p>
    {% endif %}

    {# aria-expanded lives only on the button (the lone interactive control). #}
    {# CSS reads it via :has() so the wrapper needs no state attribute.       #}
    <button type="button" class="shutter-card__toggle" aria-label="Toggle card" aria-expanded="true">
        {{ icon('close') | raw }}
    </button>
</div>
